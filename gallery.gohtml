<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>A Perfectly Adequate Image Gallery Generator</title>
    <style>
        body{
            background-color:#000;
            color:#fff;
        }

        .pagination, h1{
            display: block;
            padding: 20px;
            text-align: center;
        }
        #gallery{
            display:grid;
            grid-template-columns: repeat(3, 1fr);
            width:60%;
            margin:0 auto;
        }
        .image{
            padding: 20px;
            text-align: center;
        }
        .image img{
            max-width: 100%;
            height: auto;
        }
        .pagination a{
            color:#fff;
            padding: 0 6px;
        }
        .pagination .current{
            color:#888;
            font-weight: bold;
            padding: 0 6px;
        }
    </style>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/luminous-lightbox/2.4.0/luminous-basic.css">
</head>
<body>
    <h1>A Perfectly Adequate Image Gallery Generator</h1>

    <div id="gallery">
        {{range .Images}}
        <div class="image">
            <a href="{{.DisplayPath}}" data-caption="{{.Name}}">
                <img src="{{.ThumbPath}}" alt="{{.Name}}">
            </a>
        </div>
        {{end}}
    </div>

    <div class="pagination">
        {{if gt .CurrentPage 1}}
            <a href="gallery{{minus .CurrentPage 1}}.html">Previous</a>
        {{end}}

        {{range .PageNumbers}}
            {{if eq . $.CurrentPage}}
                <span class="current">{{.}}</span>
            {{else}}
                <a href="gallery{{.}}.html">{{.}}</a>
            {{end}}
        {{end}}

        {{if lt .CurrentPage .TotalPages}}
            <a href="gallery{{plus .CurrentPage 1}}.html">Next</a>
        {{end}}
    </div>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/luminous-lightbox/2.4.0/luminous.min.js"></script>
    <script>
    new LuminousGallery(document.querySelectorAll("#gallery a"));
    </script>
</body>
</html>
